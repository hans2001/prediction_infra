# Copy to .env on server and fill with real values.
# Do NOT commit real secrets.

# Preferred
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Alternative PG* style (used if DATABASE_URL is empty)
PGHOST=your-rds-endpoint.amazonaws.com
PGPORT=5432
PGDATABASE=prediction_infra
PGUSER=predinfra_app
PGPASSWORD=replace-me
PGSSLMODE=require
